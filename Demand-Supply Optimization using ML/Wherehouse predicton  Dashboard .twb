      <aliases enabled='yes' />
      <column caption='Alert_KPI_Message' datatype='string' name='[Calculation_1184165284869591040]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Calculation_1281274151563522050]) &lt; -5000 THEN &quot;🚨 High Risk: Immediate Supply Required&quot;&#13;&#10;ELSEIF SUM([Calculation_1281274151563522050]) &lt; 0 THEN &quot;⚠️ Moderate Risk: Monitor Closely&quot;&#13;&#10;ELSE &quot;✅ Stable: No Action Needed&quot;&#13;&#10;END' />
      </column>
      <column caption='Stock_Diff_New' datatype='real' name='[Calculation_1281274151563522050]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[current_stock] - [predicted_demand]' />
      </column>
      <column caption='Status_New' datatype='string' name='[Calculation_1281274151565074435]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1281274151563522050] &lt; -7000 THEN &quot;Stock-out&quot;&#13;&#10;ELSEIF [Calculation_1281274151563522050] &lt; -6000 THEN &quot;Balanced&quot;&#13;&#10;ELSE &quot;Overstock&quot;&#13;&#10;END' />
      </column>
      <column caption='One' datatype='integer' name='[Calculation_1281274151567388676]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Alert_Message' datatype='string' name='[Calculation_1281274151571894277]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1281274151565074435] = &quot;Stock-out&quot; THEN &quot;High Risk ⚠️&quot;&#13;&#10;ELSEIF [Calculation_1281274151565074435] = &quot;Overstock&quot; THEN &quot;Excess Inventory&quot;&#13;&#10;ELSE &quot;Stable&quot;&#13;&#10;END' />
      </column>
      <column caption='Final_Recommendation' datatype='string' name='[Calculation_1415819190476886016]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([difference]) &gt; 0 THEN &#13;&#10;&quot;Increase stock in high demand regions&quot;&#13;&#10;ELSE &#13;&#10;&quot;Reduce inventory in overstock areas&quot;&#13;&#10;END' />
      </column>
